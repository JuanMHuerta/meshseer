# Copy to .env for local overrides
# Optional app mode. Set to production on deployed hosts to disable /docs, /redoc, and /openapi.json.
# MESHSEER_ENV=development
# Optional bind overrides. Defaults to 127.0.0.1; use 0.0.0.0 only for trusted LAN testing on a dev box.
# MESHSEER_BIND_HOST=127.0.0.1
# MESHSEER_BIND_PORT=8000
# Meshtastic TCP endpoint. Required for live node data.
# MESHSEER_MESHTASTIC_HOST=192.168.1.50
# MESHSEER_MESHTASTIC_PORT=4403
# Optional persistent database path. Docker quickstart uses /data/meshseer.db.
# MESHSEER_DB_PATH=./data/meshseer.db
# Optional: enables local admin routes when set.
# MESHSEER_ADMIN_BEARER_TOKEN=replace-me
# Optional retention and prune cadence overrides. Leave retention days unset for permanent retention.
# MESHSEER_RETENTION_PACKETS_DAYS=30
# MESHSEER_RETENTION_NODE_METRIC_HISTORY_DAYS=30
# MESHSEER_RETENTION_TRACEROUTE_ATTEMPTS_DAYS=90
# MESHSEER_RETENTION_PRUNE_INTERVAL_SECONDS=86400
# Optional websocket hardening overrides.
# MESHSEER_WS_MAX_CONNECTIONS=32
# MESHSEER_WS_QUEUE_SIZE=32
# MESHSEER_WS_SEND_TIMEOUT_SECONDS=5
# MESHSEER_WS_PING_INTERVAL_SECONDS=20
# MESHSEER_WS_PING_TIMEOUT_SECONDS=20
MESHSEER_AUTOTRACE_ENABLED=false
