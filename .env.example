# Copy to .env for local overrides
# Optional app mode. Set to production on deployed hosts to disable /docs, /redoc, and /openapi.json.
# MESHRADAR_ENV=development
# Optional: enables local admin routes when set.
# MESHRADAR_ADMIN_BEARER_TOKEN=replace-me
# Optional websocket hardening overrides.
# MESHRADAR_WS_MAX_CONNECTIONS=32
# MESHRADAR_WS_QUEUE_SIZE=32
# MESHRADAR_WS_SEND_TIMEOUT_SECONDS=5
# MESHRADAR_WS_PING_INTERVAL_SECONDS=20
# MESHRADAR_WS_PING_TIMEOUT_SECONDS=20
MESHRADAR_AUTOTRACE_ENABLED=true
