MESHSEER_ENV=production
MESHSEER_BIND_HOST=127.0.0.1
MESHSEER_BIND_PORT=8000

# Replace with the host or IP of the Meshtastic node Meshseer should read from.
MESHSEER_MESHTASTIC_HOST=10.10.99.253
MESHSEER_MESHTASTIC_PORT=4403

# Store SQLite on persistent storage outside the git checkout.
MESHSEER_DB_PATH=/var/lib/meshseer/meshseer.db

# Optional if auto-detection is unreliable in your environment.
# MESHSEER_LOCAL_NODE_NUM=123456789

# Required if you want local-only admin routes available.
MESHSEER_ADMIN_BEARER_TOKEN=replace-with-a-long-random-secret

# Keep disabled unless you intentionally want background traceroutes.
MESHSEER_AUTOTRACE_ENABLED=false

# Defaults are reasonable; override only if your traffic pattern needs it.
# MESHSEER_RETENTION_PACKETS_DAYS=30
# MESHSEER_RETENTION_NODE_METRIC_HISTORY_DAYS=30
# MESHSEER_RETENTION_TRACEROUTE_ATTEMPTS_DAYS=90
# MESHSEER_RETENTION_PRUNE_INTERVAL_SECONDS=86400
# MESHSEER_WS_MAX_CONNECTIONS=32
# MESHSEER_WS_QUEUE_SIZE=32
# MESHSEER_WS_SEND_TIMEOUT_SECONDS=5
# MESHSEER_WS_PING_INTERVAL_SECONDS=20
# MESHSEER_WS_PING_TIMEOUT_SECONDS=20
